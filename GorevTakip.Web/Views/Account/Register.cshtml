@*
    Bu dosya: Kayit Ol ekrani (Ekran 2).
    Yeni kullanici olusturur. Sifre + sifre tekrari dogrulanir.
    Basarili kayitta otomatik giris yapilip Dashboard'a gidilir.
*@
@model RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">Kayıt Ol</h3>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="KullaniciAdi" class="form-label"></label>
                        <input asp-for="KullaniciAdi" class="form-control" autofocus />
                        <span asp-validation-for="KullaniciAdi" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AdSoyad" class="form-label"></label>
                        <input asp-for="AdSoyad" class="form-control" />
                        <span asp-validation-for="AdSoyad" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sifre" class="form-label"></label>
                        <input asp-for="Sifre" class="form-control" />
                        <span asp-validation-for="Sifre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SifreTekrar" class="form-label"></label>
                        <input asp-for="SifreTekrar" class="form-control" />
                        <span asp-validation-for="SifreTekrar" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Kayıt Ol</button>
                </form>

                <p class="text-center mt-3 mb-0">
                    Zaten hesabın var mı? <a asp-action="Login">Giriş yap</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
