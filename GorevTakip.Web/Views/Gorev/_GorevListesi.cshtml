@*
    Bu dosya: Gorev listesini tablo olarak basan ORTAK partial.
    Hem Index (tum gorevler) hem Filtre (bekleyen/tamamlanan) bunu kullanir -> kod tekrari yok.
    Kucuk ekranda yatay kaydirma icin table-responsive kullanildi.
*@
@model List<Gorev>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Görüntülenecek görev yok.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>Başlık</th>
                    <th>Son Tarih</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var gorev in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Detay" asp-route-id="@gorev.Id" class="fw-semibold text-decoration-none">
                                @gorev.Baslik
                            </a>
                        </td>
                        <td>@gorev.SonTarih.ToString("dd.MM.yyyy")</td>
                        <td>
                            @if (gorev.Durum == GorevDurum.Tamamlandi)
                            {
                                <span class="badge text-bg-success">Tamamlandı</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning">Bekliyor</span>
                            }
                        </td>
                        <td class="text-end">
                            @* Hizli durum degistir (tamamla / geri al) *@
                            <form asp-action="DurumDegistir" asp-route-id="@gorev.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success" title="Durumu değiştir">
                                    @(gorev.Durum == GorevDurum.Tamamlandi ? "↩" : "✓")
                                </button>
                            </form>
                            <a asp-action="Guncelle" asp-route-id="@gorev.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                            @* Silme: onay isteyen POST formu *@
                            <form asp-action="Sil" asp-route-id="@gorev.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu görevi silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
