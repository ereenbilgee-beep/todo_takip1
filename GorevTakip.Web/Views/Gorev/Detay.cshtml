@*
    Bu dosya: Gorev Detay ekrani (Ekran 7).
    Tek bir gorevin tum ayrintilarini gosterir + Duzenle / Sil / Geri butonlari.
*@
@model Gorev
@{
    ViewData["Title"] = "Görev Detayı";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">@Model.Baslik</h4>
                @if (Model.Durum == GorevDurum.Tamamlandi)
                {
                    <span class="badge text-bg-success">Tamamlandı</span>
                }
                else
                {
                    <span class="badge text-bg-warning">Bekliyor</span>
                }
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Açıklama</dt>
                    <dd class="col-sm-9" style="white-space: pre-wrap;">@(string.IsNullOrWhiteSpace(Model.Aciklama) ? "-" : Model.Aciklama)</dd>

                    <dt class="col-sm-3">Son Tarih</dt>
                    <dd class="col-sm-9">@Model.SonTarih.ToString("dd.MM.yyyy")</dd>

                    <dt class="col-sm-3">Oluşturulma</dt>
                    <dd class="col-sm-9">@Model.OlusturmaTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer bg-white d-flex gap-2">
                <a asp-action="Guncelle" asp-route-id="@Model.Id" class="btn btn-primary">Düzenle</a>
                <form asp-action="Sil" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Bu görevi silmek istediğinize emin misiniz?');">
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
                <a asp-action="Index" class="btn btn-secondary ms-auto">← Listeye Dön</a>
            </div>
        </div>
    </div>
</div>
