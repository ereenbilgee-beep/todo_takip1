@*
    Bu dosya: Gorev Ekle ekrani (Ekran 5).
    Baslik, aciklama ve son tarih alir. Form alanlari ortak _GorevForm partial'indan gelir.
*@
@model GorevFormViewModel
@{
    ViewData["Title"] = "Yeni Görev";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title mb-4">Yeni Görev Ekle</h3>

                <form asp-action="Ekle" method="post">
                    <partial name="_GorevForm" model="Model" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
